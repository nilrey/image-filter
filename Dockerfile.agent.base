FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    git \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libglib2.0-0 \
    python3-dev \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --upgrade pip setuptools wheel \
    && pip install --no-cache-dir \
       clearml==2.1.3 \
       clearml-agent==2.0.7

WORKDIR /workspace